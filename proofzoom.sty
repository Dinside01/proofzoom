\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{proofzoom}[2026/06/29 ProofZoom Complete Structural Package]

% Core Mathematics Infrastructure
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}
\RequirePackage{hyperref}

% Visual Styling Infrastructure
\RequirePackage{xcolor}
\RequirePackage{tcolorbox}
\RequirePackage{keyval}
\RequirePackage{fancyhdr}

% Core Mathematical Environments
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}
\newtheorem{proposition}{Proposition}
\newtheorem{lemma}{Lemma}
\newtheorem{corollary}{Corollary}

\theoremstyle{definition}
\newtheorem{definition}{Definition}
\newtheorem{remark}{Remark}

% Define the signature Classroom Sage Green palette
\definecolor{pzframe}{HTML}{4F7942} % Fern Green
\definecolor{pzback}{HTML}{F1F8F1}  % Soothing Mint Tint
\definecolor{pzfaintgray}{gray}{0.8} % Faint gray for the line above the slogan

% =========================================================================
% PZoom Link Configuration
% =========================================================================
% This file is global. It must not hard-code any particular entry number,
% folder, web host, or local server address.
%
% Each essay may override these in its own .tex file or wrapper, for example:
%
%   \renewcommand{\pzpdfbase}{}
%   \renewcommand{\pzmainpdf}{main-essay.pdf}
%
% If the main PDF and PZoom companion PDFs sit in the same folder,
% the default empty \pzpdfbase is usually best. For a website folder,
% an essay may instead set \pzpdfbase to that folder URL.
\providecommand{\pzpdfbase}{}
\providecommand{\pzmainpdf}{}

% Set up keyval parsing for the Goal option
\define@key{pzoom}{Goal}{\def\zp@goal{#1}}

% =========================================================================
% The Unified PZoom Macro Engine
% =========================================================================
% Usage in the main essay:
%
%   \pzoom[Goal={Prove the missing step}]{pzoom-1}{}
%
% This creates a named target body:pzoom-1 in the main PDF and links to
% pzoom-1.pdf, using \pzpdfbase as an optional prefix.
\newcommand{\pzoom}[3][Goal={Verify missing steps}]{%
  \setkeys{pzoom}{#1}%
  %
  % 1. Render any inline narrative text supplied as the third argument.
  #3%
  %
  % 2. Plant the return target in the main PDF at the PZoom box.
  \hypertarget{body:#2}{}%
  %
  % 3. Render the PZoom placeholder box.
  % The visible PZoom line is placed inside the box body and is the hyperlink.
  % This avoids the less reliable pattern of putting \href inside a tcolorbox title.
  \nopagebreak[4]\medskip
  \begin{tcolorbox}[
    colframe=pzframe,
    colback=pzback,
    arc=4pt,
    boxrule=1pt,
    size=small,
    top=5pt,
    bottom=5pt,
    left=8pt,
    right=8pt
  ]
    \noindent\href{\pzpdfbase#2.pdf}{%
      \textbf{\ensuremath{\blacktriangleright}\ PZoom: \zp@goal}%
    }%
  \end{tcolorbox}
  \medskip
}

% Usage in a PZoom companion PDF:
%
%   \pzoomreturn{pzoom-1}
%
% The link returns to the named target body:pzoom-1 in the main PDF.
% The essay-specific wrapper should define \pzmainpdf before using this.
\newcommand{\pzoomreturn}[1]{%
  \par\vspace{0.8cm}%
  \noindent
  \href{\pzpdfbase\pzmainpdf\#nameddest=body:#1}{\textbf{\ensuremath{\blacktriangleleft} Return to Main Text}}%
}

% =========================================================================
% Global Layout & Page Numbering Configuration
% =========================================================================
\pagestyle{fancy}
\fancyhf{} % Clear default layout decorations

\renewcommand{\headrulewidth}{0pt} % Strip default header rule
\renewcommand{\footrulewidth}{0pt} % Strip default footer rule

\fancyfoot[C]{\fontsize{10}{12}\selectfont\sffamily\thepage} % Standard centered page numbers

% =========================================================================
% Automated Inline Slogan Hook (Appears immediately at the text end)
% =========================================================================
\AtEndDocument{
  \vspace{1.5cm} % Blank line equivalent space below the citation block
  \begin{center}
    {\color{pzfaintgray}\hrule width \textwidth height 0.4pt}
    \vspace*{12pt} % Blank line equivalent space below the line
    {\fontsize{9}{11}\selectfont\sffamily ProofZoom $\cdot$ Foundational concepts. Bridging logical leaps with zoom-ins.}
  \end{center}
}